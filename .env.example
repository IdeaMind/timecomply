# TimeComply Environment Variables
# Copy this file to .env and fill in your values

# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# For PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/timecomply
# For SQLite (development/testing):
DATABASE_URL=sqlite:///db.sqlite3

# Email Settings (for production SMTP)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=noreply@timecomply.app

# Security (production only)
SECURE_SSL_REDIRECT=False

# Social Auth (optional, for django-allauth social providers)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
